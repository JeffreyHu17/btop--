BTOP_APP_NAME=btop Control Plane
BTOP_ENV=development
BTOP_API_PREFIX=/api/v1
BTOP_DATABASE_URL=sqlite:///./data/btop-control-plane.db
BTOP_JWT_SECRET=change-this-secret
BTOP_JWT_EXPIRE_MINUTES=720
BTOP_FRONTEND_DIST_DIR=../frontend/dist
BTOP_BOOTSTRAP_ADMIN_USERNAME=admin
BTOP_BOOTSTRAP_ADMIN_PASSWORD=admin123456
BTOP_AGENT_STALE_AFTER_SECONDS=90
BTOP_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
